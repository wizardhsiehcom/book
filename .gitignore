# mdBook build output
book/*/html/
newbook/book/*/html/
newbook/site/

# Local Python environment (uv)
newbook/.venv/

# Generated duplicated per-book assets (synced before build/serve)
newbook/docs/*/assets/
newbook/docs/*/fonts/

# Per-book synced assets (generated by sync-assets.sh, source is docs/assets/)
docs/*/assets/

# Font source archives (large, not needed for build)
docs/assets/fonts/*.zip
docs/assets/fonts/GenWanMin2-ttc/

# Source PDFs and other copyrighted materials
data/

# Vendor JS bundled into each book (tracked in template only)
book/*/mermaid.min.js
!book/template/mermaid.min.js
